# Public service
WIRECLOUD_PORT=8000

# Core app behavior
WIRECLOUD_DEBUG=false
WIRECLOUD_ALLOW_ANONYMOUS_ACCESS=true
WIRECLOUD_BASEDIR=/var/lib/wirecloud
WIRECLOUD_DEFAULT_LANGUAGE=en
WIRECLOUD_LANGUAGES=en:English,es:Spanish,pt:Portuguese

# Security (change in production)
WIRECLOUD_JWT_KEY=change-this-jwt-key-in-production-123456
WIRECLOUD_SECRET_KEY=change-this-secret-key-in-production-123456
WIRECLOUD_SESSION_AGE=1209600

# Database (MongoDB)
WIRECLOUD_DB_DRIVER=mongodb
WIRECLOUD_DB_NAME=wirecloud
WIRECLOUD_DB_HOST=mongodb
WIRECLOUD_DB_PORT=27017
WIRECLOUD_DB_USER=
WIRECLOUD_DB_PASSWORD=
WIRECLOUD_DB_USE_TRANSACTIONS=true

# Elasticsearch
WIRECLOUD_ES_HOST=elasticsearch
WIRECLOUD_ES_PORT=9200
WIRECLOUD_ES_USER=
WIRECLOUD_ES_PASSWORD=
WIRECLOUD_ES_SECURE=false

# Optional OIDC
WIRECLOUD_OIDC_ENABLED=false
WIRECLOUD_OIDC_DISCOVERY_URL=
WIRECLOUD_OIDC_CLIENT_ID=
WIRECLOUD_OIDC_CLIENT_SECRET=
WIRECLOUD_OIDC_PLUGIN=keycloak

# Optional themes
WIRECLOUD_AVAILABLE_THEMES=defaulttheme
WIRECLOUD_THEME_ACTIVE=defaulttheme
